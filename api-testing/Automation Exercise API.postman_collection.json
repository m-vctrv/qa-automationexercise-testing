          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус-код 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Тело ответа в формате JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Ответ содержит список товаров\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.products).to.exist;\r",
                  "    pm.expect(jsonData.products.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Время ответа меньше 2 секунд\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
